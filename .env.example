# ========================================
# Backend Environment Variables
# ========================================

# The secret key used for JWT authentication signing
SECRET_KEY=your_super_secret_jwt_key_change_in_production

# Gemini API Key (Required for AI Insights and Assistant Chat)
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite Database Location (Handled automatically by docker-compose)
# DATABASE_URL=sqlite:////app/data/shelfmind.db


# ========================================
# Frontend Environment Variables
# ========================================

# The URL of the backend API (Defaults to http://localhost:8000 for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
